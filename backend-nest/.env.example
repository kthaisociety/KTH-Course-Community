# PostgreSQL database connection string
DATABASE_URL=postgresql://user:password@host:port/database

# ElasticSearch credentials
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=

# SuperTokens Authentication
# Free managed instance: https://try.supertokens.com (no API key needed for dev)
ST_CONNECTION_URI=https://try.supertokens.com
ST_API_KEY=

# Google OAuth — set up at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Application URLs and Port
PORT=8080
WEBSITE_DOMAIN=http://localhost:3000
API_DOMAIN=http://localhost:8080

# Vercel AI Gateway — https://vercel.com/dashboard/ai-gateway/api-keys
AI_GATEWAY_API_KEY=
